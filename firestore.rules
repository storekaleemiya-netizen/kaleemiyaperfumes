rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isWhitelistedSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email.toLowerCase() == 'storekaleemiya@gmail.com'
      );
    }
    
    function isSuperAdmin() {
      return isWhitelistedSuperAdmin() || (isSignedIn() && getUserData().role == 'super_admin');
    }
    
    function isAdmin() {
      return isSuperAdmin() || (isSignedIn() && getUserData().role == 'admin');
    }

    // --- Data Validation Helpers ---
    function validateProduct(data) {
      return data.name is string && data.name.size() > 0
        && data.price is string && data.price.size() > 0;
    }

    function validateHeroSlide(data) {
      return (data.image is string || data.video is string || data.mobileImage is string || data.mobileVideo is string);
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        isSuperAdmin() || 
        (request.auth.uid == userId && request.resource.data.role == resource.data.role)
      );
      allow delete: if isSuperAdmin() && request.auth.token.email.toLowerCase() != 'storekaleemiya@gmail.com';
    }

    // --- Products ---
    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin() && validateProduct(request.resource.data);
      allow delete: if isAdmin();
    }
    
    // --- Hero Slides ---
    match /hero_slides/{slideId} {
      allow read: if true;
      allow create, update: if isAdmin() && validateHeroSlide(request.resource.data);
      allow delete: if isAdmin();
    }
    
    // --- Inquiries (Client Leads) ---
    match /inquiries/{inquiryId} {
      // Anyone can submit a lead, but data must be valid
      allow create: if request.resource.data.name is string 
                    && request.resource.data.phone is string;
      // Only Admins can see or manage leads
      allow read, update, delete: if isAdmin();
    }

    // --- Metadata & Config ---
    match /metadata/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // --- Gallery / Media Items ---
    match /gallery/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Orders Collection ---
    match /orders/{orderId} {
      // Users can only see and create their own orders
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid);
      // Only admins can update or delete orders
      allow update, delete: if isAdmin();
    }

    // --- News / Announcements ---
    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Reviews ---
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if isSignedIn(); // Logged in users can write reviews
    }

    // --- Default Security Layer ---
    match /{document=**} {
      allow read, write: if isWhitelistedSuperAdmin();
    }
  }
}
